{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veltrix",
  "version": "0.1.0",
  "identifier": "dev.veltrix.control-plane",
  "build": {
    "frontendDist": "../",
    "devUrl": "http://localhost:4173",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Veltrix",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
